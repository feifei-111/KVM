graph {
  config { ranks = [0, 1], kv = {layout=page_first, layer_size=4096, block_size=16, token_bytes=2} }
  ^main(%tokens: kernel.tensor<dtype=f16, shape=[8,4096]>, %wq: kernel.tensor<dtype=f16, shape=[4096,4096]>, %wk: kernel.tensor<dtype=f16, shape=[4096,4096]>, %wv: kernel.tensor<dtype=f16, shape=[4096,4096]>, %wo: kernel.tensor<dtype=f16, shape=[4096,4096]>, %meta: kernel.attn_meta<q={off=[0,8],pos=[0]}, kv={off=[0,8],pos=[0],blocks=[[0]]}, mask=causal>) {
    %q: kernel.tensor<dtype=f16, shape=[8,4096]> = kernel.matmul(%tokens, %wq)
    %k: kernel.tensor<dtype=f16, shape=[8,4096]> = kernel.matmul(%tokens, %wk)
    %v: kernel.tensor<dtype=f16, shape=[8,4096]> = kernel.matmul(%tokens, %wv)
    %qr: kernel.tensor<dtype=f16, shape=[8,4096]> = kernel.attn.rope(%q, %meta)
    %kr: kernel.tensor<dtype=f16, shape=[8,4096]> = kernel.attn.rope(%k, %meta)
    %attn: kernel.tensor<dtype=f16, shape=[8,4096]> = kernel.attn.prefill(%qr, %kr, %v, %meta)
    %out: kernel.tensor<dtype=f16, shape=[8,4096]> = kernel.matmul(%attn, %wo)
    return %out
  }
}
